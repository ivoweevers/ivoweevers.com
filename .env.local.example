# Resend — email delivery for forms (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@ivoweevers.com

# Contact form — the email address that receives form submissions
CONTACT_EMAIL=hello@ivoweevers.com

# Book pre-register — receives notification of new registrations (falls back to CONTACT_EMAIL)
BOOK_REGISTER_NOTIFY_EMAIL=ivo@ivoweevers.com

# Bonus chapter request — receives extra-chapter requests (falls back to BOOK_REGISTER_NOTIFY_EMAIL, then CONTACT_EMAIL)
BONUS_CHAPTER_NOTIFY_EMAIL=ivo@ivoweevers.com

# Umami — privacy-friendly analytics (https://cloud.umami.is). Leave WEBSITE_ID empty on preview/staging to disable.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Optional; defaults to Umami Cloud script URL if omitted
NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is/script.js
